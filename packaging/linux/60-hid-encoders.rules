# AetherSDR — USB HID encoder access for non-root users
# Install: sudo cp 60-hid-encoders.rules /etc/udev/rules.d/
# Reload: sudo udevadm control --reload-rules && sudo udevadm trigger

# Icom RC-28
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0c26", ATTRS{idProduct}=="001e", MODE="0666"
# Griffin PowerMate
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="077d", ATTRS{idProduct}=="0410", MODE="0666"
# Contour ShuttleXpress
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0b33", ATTRS{idProduct}=="0020", MODE="0666"
# Contour ShuttlePro v2
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0b33", ATTRS{idProduct}=="0030", MODE="0666"
